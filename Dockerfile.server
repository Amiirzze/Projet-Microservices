FROM gradle:8.5-jdk17 AS build
WORKDIR /app
COPY settings.gradle .
COPY stockInterface/ ./stockInterface/
COPY stockServer/    ./stockServer/
RUN gradle :stockInterface:build -x test --no-daemon
RUN gradle :stockServer:build    -x test --no-daemon
FROM eclipse-temurin:17-jre
WORKDIR /app
COPY --from=build /app/stockServer/build/libs/stockServer-0.0.1-SNAPSHOT.jar app.jar
EXPOSE 8081 9090
ENTRYPOINT ["java", "-jar", "app.jar"]
